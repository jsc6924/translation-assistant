<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:editor.ViewModels"
        xmlns:views="using:editor.Views"
        xmlns:converters="using:editor.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1280"
        d:DesignHeight="800"
        x:Class="editor.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1280"
        Height="800"
        MinWidth="960"
        MinHeight="640"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding WindowTitle}">

    <Window.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
    </Window.Resources>

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveSelectedCommand}" />
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoSelectedCommand}" />
    </Window.KeyBindings>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto,Auto">
        <Border Padding="12" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="打开文件夹" Click="OnOpenFolderClick" />
                    <Button Content="双行格式" Click="OnConfigureFormatClick" />
                    <Button Content="保存" Command="{Binding SaveSelectedCommand}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <TextBlock Text="{Binding WorkspaceLabel}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ParserSummary}" VerticalAlignment="Center" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="300,*">
            <Border Padding="12" BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="{Binding SidebarTitle}" FontSize="16" FontWeight="SemiBold" />
                    <TreeView x:Name="FileTree"
                              Grid.Row="1"
                              Margin="0,12,0,0"
                              ItemsSource="{Binding RootNodes}"
                              SelectionChanged="OnFileTreeSelectionChanged">
                    <TreeView.ItemTemplate>
                        <TreeDataTemplate x:DataType="vm:FileNodeViewModel" ItemsSource="{Binding Children}">
                            <DockPanel>
                                <DockPanel.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="新建文件"
                                                  IsVisible="{Binding IsDirectory}"
                                                  Click="OnCreateFileClick" />
                                        <MenuItem Header="删除"
                                                  Click="OnDeleteNodeClick" />
                                        <MenuItem Header="重命名"
                                                  IsVisible="{Binding IsDirectory, Converter={StaticResource InverseBooleanConverter}}"
                                                  Click="OnRenameNodeClick" />
                                    </ContextMenu>
                                </DockPanel.ContextMenu>
                                <Grid>
                                    <TextBlock Text="{Binding DisplayName}"
                                               TextTrimming="CharacterEllipsis"
                                               IsVisible="{Binding IsRenaming, Converter={StaticResource InverseBooleanConverter}}" />
                                    <TextBox Text="{Binding RenameText, Mode=TwoWay}"
                                             IsVisible="{Binding IsRenaming}"
                                             Width="200"
                                             KeyDown="OnRenameTextBoxKeyDown"
                                             LostFocus="OnRenameTextBoxLostFocus" />
                                </Grid>
                            </DockPanel>
                        </TreeDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <TabControl ItemsSource="{Binding OpenDocuments}"
                            SelectedItem="{Binding SelectedDocument, Mode=TwoWay}"
                            IsVisible="{Binding HasOpenDocuments}">
                    <TabControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:EditorDocumentViewModel">
                            <DockPanel LastChildFill="False">
                                <TextBlock Text="{Binding Header}" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <Button Content="×"
                                        Width="24"
                                        MinWidth="24"
                                        Height="24"
                                        Padding="0"
                                        Command="{Binding CloseCommand}" />
                            </DockPanel>
                        </DataTemplate>
                    </TabControl.ItemTemplate>

                    <TabControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:EditorDocumentViewModel">
                            <views:DocumentEditorView DataContext="{Binding}" />
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>

                <Border Padding="24" IsVisible="{Binding IsEditorEmpty}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                        <TextBlock Text="从左侧文件树选择一个文本文件开始编辑"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="切换标签会自动保存；配置双行格式后，原文将高亮且不可编辑。"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Padding="12" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="16">
                <CheckBox Content="启用编辑限制模式"
                          IsChecked="{Binding EnableEditRestriction, Mode=TwoWay}"
                          VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Padding="12" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}" />
        </Border>
    </Grid>

</Window>
