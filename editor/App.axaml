<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="editor.App"
             xmlns:local="using:editor"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Resources>
        <FontFamily x:Key="MyCustomFont">avares://editor/Assets/SourceHanSans-Regular.otf#Source Han Sans JP, avares://editor/Assets/SourceHanSans-Regular.otf#Source Han Sans SC, sans-serif</FontFamily>
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MyCustomFont}" />
        </Style>

        <Style Selector="TemplatedControl">
            <Setter Property="FontFamily" Value="{StaticResource MyCustomFont}" />
        </Style>

        <Style Selector="TabItem /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="FontFamily" Value="{StaticResource MyCustomFont}" />
        </Style>
        <Style Selector="TabItem TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MyCustomFont}" />
        </Style>

        <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />

        <Style Selector="TabItem">
            <Setter Property="Background" Value="{DynamicResource TabItemBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemBorderBrush}" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Background" Value="{DynamicResource TabItemSelectedBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TabItemSelectedForegroundBrush}" />
        </Style>
    </Application.Styles>
</Application>