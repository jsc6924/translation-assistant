	"publisher": "jsc723",
	"icon": "assets/logo.png",
	"description": "",
	"version": "3.3.0",
	"engines": {
		"vscode": "^1.63.0"
	},
	"categories": [
		"Programming Languages"
	],
	"activationEvents": [
		"onLanguage:dltxt",
		"onLanguage:sltxt"
