{
	"name": "translateassistant",
	"displayName": "DLTXT: 双行文本翻译解决方案",
	"publisher": "jsc723",
	"icon": "assets/logo.png",
	"description": "",
	"version": "2.25.1",
	"engines": {
		"vscode": "^1.48.0"
	},
	"categories": [
		"Programming Languages"
	],
	"activationEvents": [
		"onLanguage:dltxt",
		"onLanguage:sltxt"
	],
	"main": "./out/main.js",
	"contributes": {
		"languages": [
			{
				"id": "dltxt",
				"aliases": [
					"Double Line TXT for translation"
				],
				"extensions": [
					".txt"
				]
			},
			{
				"id": "sltxt",
				"aliases": [
					"Single Line TXT translation extracted from dltxt"
				],
				"extensions": [
					".txt.sl"
				]
			}
		],
		"grammars": [
			{
				"language": "dltxt",
				"scopeName": "source.txt",
				"path": "./syntaxes/dltxt.tmLanguage.json"
			}
		],
		"themes": [
			{
				"label": "DLTXT Dark+",
				"uiTheme": "vs-dark",
				"path": "themes/dltxt_dark.json"
			},
			{
				"label": "DLTXT Light+",
				"uiTheme": "vs",
				"path": "themes/dltxt_light.json"
			}
		],
		"colors": [
			{
				"id": "myextension.largeNumberBackground",
				"description": "Background decoration color for large numbers",
				"defaults": {
					"dark": "#FF000055",
					"light": "#FF000055",
					"highContrast": "#FF000055"
				}
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "dltxt-view-container",
					"title": "dltxt",
					"icon": "assets/logo.png"
				}
			]
		},
		"views": {
			"dltxt-view-container": [
				{
					"id": "dltxt_dict",
					"name": "dictionary"
				}
			]
		},
		"commands": [
			{
				"command": "cwt_cucumber.item_clicked",
				"title": "cwt tree view item"
			},
			{
				"command": "cwt_cucumber.refresh",
				"title": "refresh"
			},
			{
				"command": "Extension.dltxt.copyToClipboard",
				"title": "复制到剪贴板",
				"args": [
					{ "name": "text", "type": "string", "description": "Text to copy" }
				]
			},
			{
				"command": "Extension.dltxt.sync_database",
				"title": "拉取云端词条",
				"category": "DLTXT"
			},
			{
				"command": "Extension.dltxt.context_menu_insert",
				"title": "添加词条",
				"category": "DLTXT"
			},
			{
				"command": "Extension.dltxt.context_menu_update",
				"title": "更新词条",
				"category": "DLTXT"
			},
			{
				"command": "Extension.dltxt.extract_single_line",
				"title": "提取译文",
				"category": "DLTXT"
			},
			{
				"command": "Extension.dltxt.merge_into_double_line",
				"title": "应用译文至双行文本",
				"category": "DLTXT"
			},
			{
				"command": "Extension.dltxt.copy_original",
				"title": "复制原文到未翻译的译文行",
				"category": "DLTXT"
			},
			{
				"command": "Extension.dltxt.convertToEncoding",
				"title": "批量转换文件编码格式",
				"category": "DLTXT"
			},
			{
				"command": "Extension.dltxt.dlbuild.extract",
				"title": "将脚本提取为双行文本 (dlbuild.extract)",
				"category": "DLTXT"
			},
			{
				"command": "Extension.dltxt.dlbuild.pack",
				"title": "用双行文本的翻译替换脚本中的原文 (dlbuild.pack)",
				"category": "DLTXT"
			},
			{
				"command": "Extension.dltxt.spellCheck",
				"title": "译文错别字检查",
				"category": "DLTXT"
			},
			{
				"command": "Extension.dltxt.spellCheckClear",
				"title": "清除错别字检查结果",
				"category": "DLTXT"
			}
		],
		"keybindings": [
			{
				"command": "Extension.dltxt.cursorToNextLine",
				"key": "alt+enter"
			},
			{
				"command": "Extension.dltxt.cursorToPrevLine",
				"key": "alt+\\"
			},
			{
				"command": "Extension.dltxt.cursorToNextLine",
				"key": "ctrl+enter"
			},
			{
				"command": "Extension.dltxt.cursorToPrevLine",
				"key": "ctrl+\\"
			},
			{
				"command": "Extension.dltxt.cursorToNextWord",
				"key": "alt+]"
			},
			{
				"command": "Extension.dltxt.cursorToPrevWord",
				"key": "alt+["
			},
			{
				"command": "Extension.dltxt.cursorToLineHead",
				"key": "alt+u"
			},
			
			{
				"command": "Extension.dltxt.cursorToLineEnd",
				"key": "alt+p"
			},
			{
				"command": "Extension.dltxt.cursorToSublineHead",
				"key": "alt+i"
			},
			{
				"command": "Extension.dltxt.cursorToSublineEnd",
				"key": "alt+o"
			},
			{
				"command": "Extension.dltxt.moveToNextLine",
				"key": "ctrl+alt+enter"
			},
			{
				"command": "Extension.dltxt.moveToPrevLine",
				"key": "ctrl+alt+\\"
			},
			{
				"command": "Extension.dltxt.deleteUntilPunc",
				"key": "alt+backspace"
			},
			{
				"command": "Extension.dltxt.deleteAllAfter",
				"key": "alt+delete"
			},
			{
				"command": "Extension.dltxt.repeatFirst",
				"key": "ctrl+alt+space"
			}
		],
		"menus": {
			"explorer/context": [
				{
					"command": "Extension.dltxt.convertToEncoding",
					"group": "navigation"
				},
				{
					"command": "Extension.dltxt.dlbuild.extract",
					"group": "navigation"
				},
				{
					"command": "Extension.dltxt.dlbuild.pack",
					"group": "navigation"
				}
			],
			"editor/context": [
				{
					"when": "editorHasSelection && resourceLangId == dltxt",
					"command": "Extension.dltxt.context_menu_insert",
					"group": "dltxt.simpleTM.a"
				},
				{
					"when": "editorHasSelection && resourceLangId == dltxt",
					"command": "Extension.dltxt.context_menu_update",
					"group": "dltxt.simpleTM.a"
				},
				{
					"when": "resourceLangId == dltxt",
					"command": "Extension.dltxt.extract_single_line",
					"group": "dltxt.extract"
				},
				{
					"when": "resourceLangId == dltxt || resourceLangId == sltxt",
					"command": "Extension.dltxt.merge_into_double_line",
					"group": "dltxt.extract"
				},
				{
					"when": "resourceLangId == dltxt",
					"command": "Extension.dltxt.copy_original",
					"group": "dltxt.edit"
				},
				{
					"when": "resourceLangId == dltxt",
					"command": "Extension.dltxt.spellCheck",
					"group": "dltxt.edit"
				},
				{
					"when": "resourceLangId == dltxt",
					"command": "Extension.dltxt.spellCheckClear",
					"group": "dltxt.edit"
				}
			],
			"view/title": [
				{
					"command": "cwt_cucumber.refresh",
					"when": "view == cwt_cucumber",
					"group": "navigation@0"
				}
			]
		},
		"configuration": {
			"title": "dltxt",
			"properties": {
				"dltxt.simpleTM.remoteHost": {
					"type": "string",
					"default": "https://simpletm.jscrosoft.com/",
					"description": "SimpleTM服务器网址"
				},
				"dltxt.simpleTM.username": {
					"type": "string",
					"description": "SimpleTM用户名"
				},
				"dltxt.simpleTM.apiToken": {
					"type": "string",
					"description": "SimpleTM APIToken （登录后可以在你的主页上找到）"
				},
				"dltxt.simpleTM.project": {
					"type": "string",
					"description": "SimpleTM项目名（建议在Workspace中填写）"
				},
				"dltxt.core.originalTextPrefixRegex": {
					"type": "string",
					"default": "(\\[[a-z0-9]+\\])|((★|○)[a-z0-9]+(★|○))|((<\\d+>)?//)",
					"description": "原文开头标签的正则表达式"
				},
				"dltxt.core.translatedTextPrefixRegex": {
					"type": "string",
					"default": "(;\\[[a-z0-9]+\\])|((☆|●)[a-z0-9]+(☆|●))|(<\\d+>(?!//))|((//[^\n]*\n)(?!<\\d+>))",
					"description": "译文开头标签的正则表达式"
				},
				"dltxt.core.otherPrefixRegex": {
					"type": "string",
					"default": "",
					"description": "其他合法的开头的正则表达式"
				},
				"dltxt.core.z.skipCharsPrefix": {
					"type": "string",
					"default": " \t　「『n\\",
					"description": "移动至译文开头时可以跳过的字符（用于nextLine等）"
				},
				"dltxt.core.z.textDelimiter": {
					"type": "string",
					"default": "[，。、？！…—；：“”‘’~～\\s　「」『』\\[\\]\\(\\)（）【】]|(\\\\@)",
					"description": "分割句段的正则表达式（用于repeatFirstChar/deleteUntilPunc）"
				},
				"dltxt.appearance.showKeywordHighlight": {
					"type": "boolean",
					"default": true,
					"description": "外观：显示关键词高亮"
				},
				"dltxt.appearance.showErrorHighlight": {
					"type": "boolean",
					"default": true,
					"description": "外观：显示错误"
				},
				"dltxt.formatter.a.padding": {
					"type": "boolean",
					"default": true,
					"description": "格式化文本：统一缩进与对话外的单括号（「」）"
				},
				"dltxt.formatter.a.ellipsis.enable": {
					"type": "boolean",
					"default": true,
					"description": "格式化文本：统一省略号"
				},
				"dltxt.formatter.a.ellipsis.specify": {
					"type": "string",
					"default": "……",
					"description": "格式化文本：省略号统一改为"
				},
				"dltxt.formatter.a.wave.enable": {
					"type": "boolean",
					"default": true,
					"description": "格式化文本：统一波浪号"
				},
				"dltxt.formatter.a.wave.specify": {
					"type": "string",
					"default": "～",
					"description": "格式化文本：波浪号统一改为"
				},
				"dltxt.formatter.a.horizontalLine.enable": {
					"type": "boolean",
					"default": true,
					"description": "格式化文本：统一破折号"
				},
				"dltxt.formatter.a.horizontalLine.specify": {
					"type": "string",
					"default": "——",
					"description": "格式化文本：破折号统一改为"
				},
				"dltxt.formatter.b.fixReversedQuote": {
					"type": "boolean",
					"default": true,
					"description": "格式化文本：统一写反的、或半角的单引号、双引号（”ａ“）"
				},
				"dltxt.formatter.b.h2fPunc": {
					"type": "boolean",
					"default": true,
					"description": "格式化文本：将常用标点符号统一为中文全角标点（半角引号除外）"
				},
				"dltxt.formatter.b.h2fAlpha": {
					"type": "boolean",
					"default": false,
					"description": "格式化文本：将英文与数字统一为全角（如果文本中有英文脚本请勿使用）"
				},
				"dltxt.formatter.c.omitPeriod": {
					"type": "boolean",
					"default": true,
					"description": "格式化文本：去除对话句末的句号"
				},
				"dltxt.formatter.d.customMapping": {
					"type": "object",
					"default": {},
					"description": "格式化文本：自定义翻译表",
					"additionalProperties": {
						"type": "string"
					}
				},
				"dltxt.motion.moveToNextLine.moveCursor": {
					"type": "boolean",
					"default": true,
					"description": "快捷键：把光标后译文移动到下一行时同时移动光标"
				},
				"dltxt.z.api.baidu.AccessKey": {
					"type": "string",
					"description": "百度智能云API AccessKey"
				},
				"dltxt.z.api.baidu.SecretKey": {
					"type": "string",
					"description": "百度智能云API AccessKey"
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile && npm run esbuild-base -- --minify",
		"compile": "tsc -p ./",
		"lint": "eslint src --ext ts",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint",
		"test": "node ./out/test/runTest.js",
		"esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/main.js --external:vscode --format=cjs --platform=node",
		"esbuild": "npm run esbuild-base -- --sourcemap",
		"esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
		"test-compile": "tsc -p ./"
	},
	"devDependencies": {
		"@types/glob": "^7.1.1",
		"@types/js-yaml": "^4.0.5",
		"@types/mocha": "^7.0.2",
		"@types/node": "^13.11.0",
		"@types/vscode": "^1.47.0",
		"@typescript-eslint/eslint-plugin": "^2.30.0",
		"@typescript-eslint/parser": "^2.30.0",
		"esbuild": "^0.17.19",
		"eslint": "^6.8.0",
		"glob": "^7.1.6",
		"mocha": "^7.1.2",
		"typescript": "^3.8.3",
		"vscode-test": "^1.3.0"
	},
	"dependencies": {
		"axios": "^0.19.2",
		"iconv-lite": "^0.6.3",
		"js-yaml": "^4.1.0",
		"open": "^7.4.2",
		"request": "^2.88.2"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/jsc723/translation-assistant.git"
	}
}
