{
	"name": "translateassistant",
	"displayName": "DLTXT: 双行文本翻译解决方案",
	"publisher": "jsc723",
	"icon": "assets/logo.png",
	"description": "",
	"version": "2.33.0",
	"engines": {
		"vscode": "^1.48.0"
	},
	"categories": [
		"Programming Languages"
	],
	"activationEvents": [
		"onLanguage:dltxt",
		"onLanguage:sltxt"
	],
	"main": "./out/main.js",
	"contributes": {
		"languages": [
			{
				"id": "dltxt",
				"aliases": [
					"Double Line TXT for translation"
				],
				"extensions": [
					".txt"
				]
			},
			{
				"id": "sltxt",
				"aliases": [
					"Single Line TXT translation extracted from dltxt"
				],
				"extensions": [
					".txt.sl"
				]
			}
		],
		"grammars": [
			{
				"language": "dltxt",
				"scopeName": "source.txt",
				"path": "./syntaxes/dltxt.tmLanguage.json"
			}
		],
		"themes": [
			{
				"label": "DLTXT Dark+",
				"uiTheme": "vs-dark",
				"path": "themes/dltxt_dark.json"
			},
			{
				"label": "DLTXT Light+",
				"uiTheme": "vs",
				"path": "themes/dltxt_light.json"
			}
		],
		"colors": [
			{
				"id": "myextension.largeNumberBackground",
				"description": "Background decoration color for large numbers",
				"defaults": {
					"dark": "#FF000055",
					"light": "#FF000055",
					"highContrast": "#FF000055"
				}
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "dltxt-view-container",
					"title": "dltxt",
					"icon": "assets/logo.png"
				}
			]
		},
		"views": {
			"dltxt-view-container": [
				{
					"id": "dltxt-dict",
					"name": "dictionary"
				},
				{
					"id": "dltxt-clipboard",
					"name": "clickboard"
				}
			]
		},
		"commands": [
			{
				"command": "Extension.dltxt.copyToClipboard",
				"title": "复制到剪贴板",
				"args": [
					{
						"name": "text",
						"type": "string",
						"description": "Text to copy"
					}
				]
			},
			{
				"command": "Extension.dltxt.sync_database",
				"title": "拉取云端词条",
				"category": "DLTXT",
				"icon": {
					"dark": "icons/dark/sync.svg",
					"light": "icons/light/sync.svg"
				}
			},
			{
				"command": "Extension.dltxt.context_menu_insert",
				"title": "添加词条",
				"category": "DLTXT"
			},
			{
				"command": "Extension.dltxt.context_menu_update",
				"title": "更新词条",
				"category": "DLTXT"
			},
			{
				"command": "Extension.dltxt.extract_single_line",
				"title": "提取译文",
				"category": "DLTXT"
			},
			{
				"command": "Extension.dltxt.merge_into_double_line",
				"title": "应用译文至双行文本",
				"category": "DLTXT"
			},
			{
				"command": "Extension.dltxt.copy_original",
				"title": "复制原文到未翻译的译文行",
				"category": "DLTXT"
			},
			{
				"command": "Extension.dltxt.convertToEncoding",
				"title": "批量转换文件编码格式",
				"category": "DLTXT"
			},
			{
				"command": "Extension.dltxt.dlbuild.extract",
				"title": "将脚本提取为双行文本 (dlbuild.extract)",
				"category": "DLTXT"
			},
			{
				"command": "Extension.dltxt.dlbuild.pack",
				"title": "用双行文本的翻译替换脚本中的原文 (dlbuild.pack)",
				"category": "DLTXT"
			},
			{
				"command": "Extension.dltxt.spellCheck",
				"title": "译文错别字检查",
				"category": "DLTXT"
			},
			{
				"command": "Extension.dltxt.spellCheckClear",
				"title": "清除错别字检查结果",
				"category": "DLTXT"
			},
			{
				"command": "Extension.dltxt.treeview.editItem",
				"title": "编辑术语",
				"icon": {
					"light": "icons/light/edit.svg",
					"dark": "icons/dark/edit.svg"
				}
			},
			{
				"command": "Extension.dltxt.treeview.deleteItem",
				"title": "删除术语",
				"icon": {
					"light": "icons/light/trash.svg",
					"dark": "icons/dark/trash.svg"
				}
			},
			{
				"command": "Extension.dltxt.treeview.setClipboardString",
				"title": "编辑剪贴板",
				"icon": {
					"light": "icons/light/edit.svg",
					"dark": "icons/dark/edit.svg"
				}
			},
			{
				"command": "Extension.dltxt.trdb.addDocument",
				"title": "添加当前文本到翻译数据库",
				"icon": {
					"dark": "icons/dark/add.svg",
					"light": "icons/light/add.svg"
				}
			},
			{
				"command": "Extension.dltxt.trdb.searchText",
				"title": "在翻译数据库搜索",
				"icon": {
					"dark": "icons/dark/search.svg",
					"light": "icons/light/search.svg"
				}
			}
		],
		"keybindings": [
			{
				"command": "Extension.dltxt.cursorToNextLine",
				"key": "alt+enter",
				"when": "editorTextFocus && resourceLangId == dltxt"
			},
			{
				"command": "Extension.dltxt.cursorToNextLine",
				"key": "enter",
				"when": "editorTextFocus && resourceLangId == dltxt && dltxt.mode == 'Translate'"
			},
			{
				"command": "Extension.dltxt.cursorToPrevLine",
				"key": "alt+\\",
				"when": "editorTextFocus && resourceLangId == dltxt"
			},
			{
				"command": "Extension.dltxt.cursorToPrevLine",
				"key": "\\",
				"when": "editorTextFocus && resourceLangId == dltxt && dltxt.mode == 'Translate'"
			},
			{
				"command": "Extension.dltxt.cursorToNextLine",
				"key": "ctrl+enter",
				"when": "editorTextFocus && resourceLangId == dltxt"
			},
			{
				"command": "Extension.dltxt.cursorToPrevLine",
				"key": "ctrl+\\",
				"when": "editorTextFocus && resourceLangId == dltxt"
			},
			{
				"command": "Extension.dltxt.cursorToNextWord",
				"key": "]",
				"when": "editorTextFocus && resourceLangId == dltxt && dltxt.mode == 'Translate'"
			},
			{
				"command": "Extension.dltxt.cursorToPrevWord",
				"key": "[",
				"when": "editorTextFocus && resourceLangId == dltxt && dltxt.mode == 'Translate'"
			},
			{
				"command": "Extension.dltxt.cursorToNextWord",
				"key": "alt+]",
				"when": "editorTextFocus && resourceLangId == dltxt"
			},
			{
				"command": "Extension.dltxt.cursorToPrevWord",
				"key": "alt+[",
				"when": "editorTextFocus && resourceLangId == dltxt"
			},
			{
				"command": "Extension.dltxt.cursorToSublineHead",
				"key": "shift+alt+[",
				"when": "editorTextFocus && resourceLangId == dltxt"
			},
			{
				"command": "Extension.dltxt.cursorToSublineEnd",
				"key": "shift+alt+]",
				"when": "editorTextFocus && resourceLangId == dltxt"
			},
			{
				"command": "Extension.dltxt.cursorToSublineHead",
				"key": "shift+[",
				"when": "editorTextFocus && resourceLangId == dltxt && dltxt.mode == 'Translate'"
			},
			{
				"command": "Extension.dltxt.cursorToSublineEnd",
				"key": "shift+]",
				"when": "editorTextFocus && resourceLangId == dltxt && dltxt.mode == 'Translate'"
			},
			{
				"command": "Extension.dltxt.cursorToLineHead",
				"key": "ctrl+alt+[",
				"when": "editorTextFocus && resourceLangId == dltxt"
			},
			{
				"command": "Extension.dltxt.cursorToLineEnd",
				"key": "ctrl+alt+]",
				"when": "editorTextFocus && resourceLangId == dltxt"
			},
			{
				"command": "Extension.dltxt.cursorToLineHead",
				"key": "ctrl+[",
				"when": "editorTextFocus && resourceLangId == dltxt && dltxt.mode == 'Translate'"
			},
			{
				"command": "Extension.dltxt.cursorToLineEnd",
				"key": "ctrl+]",
				"when": "editorTextFocus && resourceLangId == dltxt && dltxt.mode == 'Translate'"
			},
			{
				"command": "Extension.dltxt.moveToNextLine",
				"key": "ctrl+alt+enter",
				"when": "editorTextFocus && resourceLangId == dltxt"
			},
			{
				"command": "Extension.dltxt.moveToPrevLine",
				"key": "ctrl+alt+\\",
				"when": "editorTextFocus && resourceLangId == dltxt"
			},
			{
				"command": "Extension.dltxt.deleteUntilPunc",
				"key": "alt+backspace",
				"when": "editorTextFocus && resourceLangId == dltxt && dltxt.mode == 'Normal'"
			},
			{
				"command": "Extension.dltxt.deleteUntilPunc",
				"key": "=",
				"when": "editorTextFocus && resourceLangId == dltxt && dltxt.mode == 'Translate'"
			},
			{
				"command": "Extension.dltxt.deleteAllAfter",
				"key": "alt+backspace",
				"when": "editorTextFocus && resourceLangId == dltxt && dltxt.mode == 'Translate'"
			},
			{
				"command": "Extension.dltxt.deleteAllAfter",
				"key": "alt+delete",
				"when": "editorTextFocus && resourceLangId == dltxt"
			},
			{
				"command": "Extension.dltxt.repeatFirst",
				"key": "ctrl+alt+space",
				"when": "editorTextFocus && resourceLangId == dltxt"
			},
			{
				"command": "Extension.dltxt.customWriteString",
				"key": "alt+1",
				"when": "editorTextFocus && resourceLangId == dltxt",
				"args": {
					"arg1": "clipboard.customString1"
				}
			},
			{
				"command": "Extension.dltxt.customWriteString",
				"key": "alt+2",
				"when": "editorTextFocus && resourceLangId == dltxt",
				"args": {
					"arg1": "clipboard.customString2"
				}
			},
			{
				"command": "Extension.dltxt.customWriteString",
				"key": "alt+3",
				"when": "editorTextFocus && resourceLangId == dltxt",
				"args": {
					"arg1": "clipboard.customString3"
				}
			},
			{
				"command": "Extension.dltxt.customWriteString",
				"key": "alt+4",
				"when": "editorTextFocus && resourceLangId == dltxt",
				"args": {
					"arg1": "clipboard.customString4"
				}
			},
			{
				"command": "Extension.dltxt.customWriteString",
				"key": "alt+5",
				"when": "editorTextFocus && resourceLangId == dltxt",
				"args": {
					"arg1": "clipboard.customString5"
				}
			},
			{
				"command": "Extension.dltxt.customWriteString",
				"key": "alt+6",
				"when": "editorTextFocus && resourceLangId == dltxt",
				"args": {
					"arg1": "clipboard.customString6"
				}
			},
			{
				"command": "Extension.dltxt.setClipboardString",
				"key": "ctrl+alt+1",
				"when": "editorTextFocus  && resourceLangId == dltxt",
				"args": {
					"arg1": "clipboard.customString1"
				}
			},
			{
				"command": "Extension.dltxt.setClipboardString",
				"key": "ctrl+alt+2",
				"when": "editorTextFocus  && resourceLangId == dltxt",
				"args": {
					"arg1": "clipboard.customString2"
				}
			},
			{
				"command": "Extension.dltxt.setClipboardString",
				"key": "ctrl+alt+3",
				"when": "editorTextFocus  && resourceLangId == dltxt",
				"args": {
					"arg1": "clipboard.customString3"
				}
			},
			{
				"command": "Extension.dltxt.setClipboardString",
				"key": "ctrl+alt+4",
				"when": "editorTextFocus  && resourceLangId == dltxt",
				"args": {
					"arg1": "clipboard.customString4"
				}
			},
			{
				"command": "Extension.dltxt.setClipboardString",
				"key": "ctrl+alt+5",
				"when": "editorTextFocus  && resourceLangId == dltxt",
				"args": {
					"arg1": "clipboard.customString5"
				}
			},
			{
				"command": "Extension.dltxt.setClipboardString",
				"key": "ctrl+alt+6",
				"when": "editorTextFocus  && resourceLangId == dltxt",
				"args": {
					"arg1": "clipboard.customString6"
				}
			},
			{
				"command": "type",
				"key": "shift+`",
				"when": "editorTextFocus && resourceLangId == dltxt && dltxt.mode == 'Translate'",
				"args": {
					"soucre": "keyboard",
					"text": "～"
				}
			},
			{
				"command": "type",
				"key": "1",
				"when": "editorTextFocus && resourceLangId == dltxt && dltxt.mode == 'Translate'",
				"args": {
					"soucre": "keyboard",
					"text": "！"
				}
			},
			{
				"command": "type",
				"key": "2",
				"when": "editorTextFocus && resourceLangId == dltxt && dltxt.mode == 'Translate'",
				"args": {
					"soucre": "keyboard",
					"text": "♪"
				}
			},
			{
				"command": "type",
				"key": "3",
				"when": "editorTextFocus && resourceLangId == dltxt && dltxt.mode == 'Translate'",
				"args": {
					"soucre": "keyboard",
					"text": "？"
				}
			},
			{
				"command": "type",
				"key": "6",
				"when": "editorTextFocus && resourceLangId == dltxt && dltxt.mode == 'Translate'",
				"args": {
					"soucre": "keyboard",
					"text": "……"
				}
			},
			{
				"command": "type",
				"key": "-",
				"when": "editorTextFocus && resourceLangId == dltxt && dltxt.mode == 'Translate'",
				"args": {
					"soucre": "keyboard",
					"text": "——"
				}
			},
			{
				"command": "type",
				"key": "space",
				"when": "editorTextFocus && resourceLangId == dltxt && dltxt.mode == 'Translate'",
				"args": {
					"soucre": "keyboard",
					"text": "　"
				}
			},
			{
				"command": "Extension.dltxt.setMode",
				"key": "escape",
				"when": "editorTextFocus && resourceLangId == dltxt && dltxt.mode != 'Normal'",
				"args": {
					"arg": "Normal"
				}
			},
			{
				"command": "Extension.dltxt.setMode",
				"key": "alt+t",
				"when": "editorTextFocus && resourceLangId == dltxt && dltxt.mode == 'Normal'",
				"args": {
					"arg": "Translate"
				}
			}
		],
		"menus": {
			"explorer/context": [
				{
					"command": "Extension.dltxt.convertToEncoding",
					"group": "navigation"
				},
				{
					"command": "Extension.dltxt.dlbuild.extract",
					"group": "navigation"
				},
				{
					"command": "Extension.dltxt.dlbuild.pack",
					"group": "navigation"
				}
			],
			"editor/context": [
				{
					"when": "editorHasSelection && resourceLangId == dltxt",
					"command": "Extension.dltxt.context_menu_insert",
					"group": "dltxt.simpleTM.a"
				},
				{
					"when": "editorHasSelection && resourceLangId == dltxt",
					"command": "Extension.dltxt.context_menu_update",
					"group": "dltxt.simpleTM.a"
				},
				{
					"when": "resourceLangId == dltxt",
					"command": "Extension.dltxt.extract_single_line",
					"group": "dltxt.extract"
				},
				{
					"when": "resourceLangId == dltxt || resourceLangId == sltxt",
					"command": "Extension.dltxt.merge_into_double_line",
					"group": "dltxt.extract"
				},
				{
					"when": "resourceLangId == dltxt",
					"command": "Extension.dltxt.copy_original",
					"group": "dltxt.edit"
				},
				{
					"when": "resourceLangId == dltxt",
					"command": "Extension.dltxt.spellCheck",
					"group": "dltxt.edit"
				},
				{
					"when": "resourceLangId == dltxt",
					"command": "Extension.dltxt.spellCheckClear",
					"group": "dltxt.edit"
				}
			],
			"view/title": [
				{
					"command": "Extension.dltxt.sync_database",
					"when": "view == dltxt-dict",
					"group": "navigation@1"
				}
			],
			"view/item/context": [
				{
					"command": "Extension.dltxt.treeview.editItem",
					"when": "view == dltxt-dict && viewItem == key-value-item",
					"group": "inline@1"
				},
				{
					"command": "Extension.dltxt.treeview.deleteItem",
					"when": "view == dltxt-dict && viewItem == key-value-item",
					"group": "inline@2"
				},
				{
					"command": "Extension.dltxt.treeview.setClipboardString",
					"when": "view == dltxt-clipboard && viewItem == value-item",
					"group": "inline@1"
				}
			]
		},
		"configuration": {
			"title": "dltxt",
			"properties": {
				"dltxt.simpleTM.remoteHost": {
					"type": "string",
					"default": "https://simpletm.jscrosoft.com/",
					"description": "SimpleTM服务器网址"
				},
				"dltxt.simpleTM.username": {
					"type": "string",
					"description": "SimpleTM用户名"
				},
				"dltxt.simpleTM.apiToken": {
					"type": "string",
					"description": "SimpleTM APIToken （登录后可以在你的主页上找到）"
				},
				"dltxt.simpleTM.project": {
					"type": "string",
					"description": "SimpleTM项目名（建议在Workspace中填写）"
				},
				"dltxt.simpleTM.syncInterval": {
					"type": "integer",
					"default": 300,
					"description": "SimpleTM数据库自动同步间隔（单位：秒，最小30秒。填0不自动更新）"
				},
				"dltxt.core.originalTextPrefixRegex": {
					"type": "string",
					"default": "(\\[[a-z0-9]+\\])|((★|○)[a-z0-9]+(★|○))|((<\\d+>)?//)",
					"description": "原文开头标签的正则表达式"
				},
				"dltxt.core.translatedTextPrefixRegex": {
					"type": "string",
					"default": "(;\\[[a-z0-9]+\\])|((☆|●)[a-z0-9]+(☆|●))|(<\\d+>(?!//))|((//[^\n]*\n)(?!<\\d+>))",
					"description": "译文开头标签的正则表达式"
				},
				"dltxt.core.otherPrefixRegex": {
					"type": "string",
					"default": "",
					"description": "其他合法的开头的正则表达式"
				},
				"dltxt.core.z.skipCharsPrefix": {
					"type": "string",
					"default": " \t　「『n\\",
					"description": "移动至译文开头时可以跳过的字符（用于nextLine等）"
				},
				"dltxt.core.z.textDelimiter": {
					"type": "string",
					"default": "[，。、？！…—；：“”‘’~～\\s　「」『』\\[\\]\\(\\)（）【】]|(\\\\@)",
					"description": "分割句段的正则表达式（用于repeatFirstChar/deleteUntilPunc）"
				},
				"dltxt.appearance.showKeywordHighlight": {
					"type": "boolean",
					"default": true,
					"description": "外观：显示关键词高亮"
				},
				"dltxt.appearance.showErrorHighlight": {
					"type": "boolean",
					"default": true,
					"description": "外观：显示错误"
				},
				"dltxt.formatter.a.padding": {
					"type": "boolean",
					"default": true,
					"description": "格式化文本：统一缩进与对话外的单括号（「」）"
				},
				"dltxt.formatter.a.ellipsis.enable": {
					"type": "boolean",
					"default": true,
					"description": "格式化文本：统一省略号"
				},
				"dltxt.formatter.a.ellipsis.specify": {
					"type": "string",
					"default": "……",
					"description": "格式化文本：省略号统一改为"
				},
				"dltxt.formatter.a.wave.enable": {
					"type": "boolean",
					"default": true,
					"description": "格式化文本：统一波浪号"
				},
				"dltxt.formatter.a.wave.specify": {
					"type": "string",
					"default": "～",
					"description": "格式化文本：波浪号统一改为"
				},
				"dltxt.formatter.a.horizontalLine.enable": {
					"type": "boolean",
					"default": true,
					"description": "格式化文本：统一破折号"
				},
				"dltxt.formatter.a.horizontalLine.specify": {
					"type": "string",
					"default": "——",
					"description": "格式化文本：破折号统一改为"
				},
				"dltxt.formatter.b.fixReversedQuote": {
					"type": "boolean",
					"default": true,
					"description": "格式化文本：统一写反的、或半角的单引号、双引号（”ａ“）"
				},
				"dltxt.formatter.b.h2fPunc": {
					"type": "boolean",
					"default": true,
					"description": "格式化文本：将常用标点符号统一为中文全角标点（半角引号除外）"
				},
				"dltxt.formatter.b.h2fAlpha": {
					"type": "boolean",
					"default": false,
					"description": "格式化文本：将英文与数字统一为全角（如果文本中有英文脚本请勿使用）"
				},
				"dltxt.formatter.c.omitPeriod": {
					"type": "boolean",
					"default": true,
					"description": "格式化文本：去除对话句末的句号"
				},
				"dltxt.formatter.d.customMapping": {
					"type": "object",
					"default": {},
					"description": "格式化文本：自定义翻译表",
					"additionalProperties": {
						"type": "string"
					}
				},
				"dltxt.spellingCheck.skipSet": {
					"type": "array",
					"default": [],
					"items": {
						"type": "string"
					},
					"description": "错别字检查：跳过的字段（例如人名）"
				},
				"dltxt.motion.moveToNextLine.moveCursor": {
					"type": "boolean",
					"default": true,
					"description": "快捷键：把光标后译文移动到下一行时同时移动光标"
				},
				"dltxt.z.api.baidu.AccessKey": {
					"type": "string",
					"description": "百度智能云API AccessKey"
				},
				"dltxt.z.api.baidu.SecretKey": {
					"type": "string",
					"description": "百度智能云API AccessKey"
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile && npm run esbuild-base -- --minify",
		"compile": "tsc -p ./",
		"lint": "eslint src --ext ts",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint",
		"test": "node ./out/test/runTest.js",
		"esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/main.js --external:vscode --format=cjs --platform=node",
		"esbuild": "npm run esbuild-base -- --sourcemap",
		"esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
		"test-compile": "tsc -p ./"
	},
