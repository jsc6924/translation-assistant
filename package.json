		],
		"themes": [
			{
				"label": "DLTXT Dark+",
				"uiTheme": "vs-dark",
				"path": "themes/dltxt_dark.json"
			},
			{
				"label": "DLTXT Light+",
				"uiTheme": "vs",
				"path": "themes/dltxt_light.json"
			}
		],
		"colors": [
